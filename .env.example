# ============================================================
# Patriot Lens Bot — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ----------------------------
# Twitter / X API credentials
# (required for live posting)
# ----------------------------
TW_CONSUMER_KEY=your_consumer_key_here
TW_CONSUMER_SECRET=your_consumer_secret_here
TW_ACCESS_TOKEN=your_access_token_here
TW_ACCESS_SECRET=your_access_token_secret_here

# ----------------------------
# OpenAI API
# ----------------------------
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the primary tweet-generation model.
# Default: gpt-4.1-mini. Fallback chain: gpt-4o -> gpt-4o-mini
# OPENAI_TWEET_MODEL=gpt-4.1-mini
# OPENAI_TWEET_MODEL_FALLBACKS=gpt-4o,gpt-4o-mini

# ----------------------------
# NewsAPI
# ----------------------------
NEWS_API_KEY=your_newsapi_key_here

# ----------------------------
# Posting schedule
# ----------------------------
# Override the default 5-slot schedule with a comma-separated list of
# HH:MM times in Eastern time.  Format rotation is automatic:
#   - Last slot  -> numbered_thread (2-tweet thread)
#   - Odd index  -> question_cta    (drives replies)
#   - Even index -> single
# Example (matches default):
# POSTING_TIMES=07:00,11:30,13:00,17:30,21:00

# ----------------------------
# Logging
# ----------------------------
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ----------------------------
# Retry / resilience
# ----------------------------
# Number of POST /2/tweets attempts before giving up and writing to
# failed_queue.csv.  Delays: 2s, 4s, 8s between attempts.
MAX_RETRY_ATTEMPTS=3

# ----------------------------
# Dry-run (set to 1 to log without posting)
# ----------------------------
# DRY_RUN=1
